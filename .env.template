# ElderCare Environment Variables
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# === MQTT Broker ===
MQTT_BROKER=localhost
MQTT_PORT=1883

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID_PRIMARY=your_chat_id_here
# TELEGRAM_CHAT_ID_SECONDARY=another_chat_id

# === InfluxDB (Time-Series Database) ===
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_influxdb_token
INFLUXDB_ORG=eldercare
INFLUXDB_BUCKET=eldercare_metrics
INFLUXDB_ADMIN_PASSWORD=changeme

# === Dashboard ===
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# === Dashboard Authentication ===
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=eldercare
DASHBOARD_SECRET_KEY=change-this-to-a-random-secret-string
DASHBOARD_TOKEN_EXPIRE_HOURS=24

# === UDP Bridge (RuView ESP32 firmware) ===
UDP_BRIDGE_LISTEN_PORT=5005
UDP_BRIDGE_MQTT_BROKER=localhost
UDP_BRIDGE_MQTT_PORT=1883

# === Webhook Alert Channel (optional, alternative to Telegram) ===
# WEBHOOK_URL=https://your-webhook.example.com/alerts
# WEBHOOK_HEADERS={\"Authorization\": \"Bearer your-token\"}
# WEBHOOK_RETRY_COUNT=3
# WEBHOOK_TIMEOUT_SEC=10

# === Alert Language ===
ALERT_LANGUAGE=vi
ALERT_TIMEZONE=Asia/Ho_Chi_Minh

# === Model Device ===
INFERENCE_DEVICE=cpu
